{
  "manifest_version": 3,
  "name": "Claude Synthesizer",
  "description": "In-project STATE.md synthesis for Claude AI partnership projects",
  "version": "2.5.1",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["extractor.js", "prompts.js", "claude-api.js", "orchestrator.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
